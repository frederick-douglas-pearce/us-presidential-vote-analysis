# usvote configuration template.
#
# Copy this to `.env` (which is git-ignored) and edit the values:
#
#   cp .env.example .env
#   # ...edit .env...
#   set -a; source .env; set +a     # load into the shell (quote paths with spaces)
#   python -m usvote                # add --replace for a destructive full rebuild
#
# Or export the variables individually / use direnv. No dotenv library is required.

# --- Database (standard libpq PG* variables; also read by psql, pg_dump, etc.) ---
# Defaults shown are what the pipeline falls back to when a variable is unset.
PGHOST=localhost
PGPORT=5432
PGDATABASE=elections
PGUSER=postgres
# Leave PGPASSWORD unset to be prompted securely at runtime (recommended — never
# commit a real password). Set it only for non-interactive/CI runs.
#PGPASSWORD=

# --- App-specific inputs ---
# Path to the unzipped TIGER2019 STATE shapefile (.shp). Required. Free download:
# https://www.census.gov/geographies/mapping-files/time-series/geo/tiger-line-file.html
USVOTE_SHAPEFILE_PATH=/path/to/tl_2019_us_state/tl_2019_us_state.shp

# Path to the MIT Election Lab 1976-2024-president.csv (required for the MIT
# popular-vote pipeline). Free CC0 1.0 download from Harvard Dataverse:
# https://doi.org/10.7910/DVN/42MVDX  — lives outside the repo, located via this var.
USVOTE_MIT_CSV_PATH=/path/to/1976-2024-president.csv

# --- E8 internal API (usvote/api/) ---
# Path to the read-only SQLite API snapshot. WRITTEN by `python -m usvote.snapshot`
# (needs the local warehouse), READ by `python -m usvote.api` at startup. The API
# serves this file with no live DB (D028).
USVOTE_API_SNAPSHOT_PATH=/path/to/snapshot.sqlite

# CORS allow-list for the API: Comma-separated list of browser origins
# permitted to call the API via JavaScript. Each entry is a full origin:
# scheme + host + port, NO trailing slash, NO path. Server-to-server calls, curl,
# and the OpenAPI docs page are unaffected — this only gates in-browser fetch().
# Defaults to localhost dev origins when unset; add the real dashboard origin here
# once the frontend is deployed (D001). Example prod value:
# USVOTE_API_CORS_ORIGINS=https://your-dashboard.example
